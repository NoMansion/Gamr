package src;
public class Community
{
    private String name;
    private List<String> genres;
    private List<User> members;
    private List<Post> communityPosts;

    /**
     * Creates new Community obejct. (When a new community is made)
     * 
     * @param name Name of the community
     * @param genres List of genres that the Community can be associated with.
     * @param members List of Users that are a part of this Community. 
     * @param communityPosts List of Posts that are made under this community.
     */
    public Community(String name, List<String> genres, List<User> members, List<Post> communityPosts)
    {
        this.name = name;
        this.genres = new ArrayList<>();
        this.members = new ArrayList<>();
        this.communityPosts = new ArrayList<>();
    } 

    /**
     * Retrieves the community objects name.
     * 
     * @return name
     */
    public String getName()
    {
        return name;
    }

    /**
     * Retrieves the list of genres associated with the community.
     * 
     * @return genres
     */
    public List<String> getGenres()
    {
        return genres;
    }

    /**
     * Retrieves the list of users that are a member of the community.
     * 
     * @return members
     */
    public List<User> getMembers()
    {
        return members;
    }

    /**
     * Retrieves the list of Posts made under this community.
     * 
     * @return communityPosts
     */
    public List<Post> getCommunityPosts()
    {
        return communityPosts;
    }

    /**
     * Sets the name of the community.
     * 
     * @param name
     */
    public void setName(String name)
    {
        this.name = name;
    }

    /**
     * Sets the list of genres of the community.
     * 
     * @param genres
     */
    public void setGenres(List<String> genres)
    {
        this.genres = genres;
    }

    /**
     * Sets the list of members in the community.
     * 
     * @param members
     */
    public void setMembers(List<User> members)
    {
        this.members = members;
    }

    /**
     * Sets the list of community posts made in the community.
     * 
     * @param communityPosts
     */
    public void setCommunityPosts(List<Post> communityPosts)
    {
        this.communityPosts = communityPosts;
    }
}
