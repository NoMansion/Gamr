package src;
public class Post
{
    private int postId;
    private User author;
    private Community community;
    private String textContent;
    private int likeCount;
    private int dislikeCount;
    private List<Comment> comments;

    /**
     * Creates a new Post object. (For when a new post is made)
     * 
     * @param author Writer of the post.
     * @param community The community the post is submitted under.
     * @param textContent What the author writes to be in the post.
     * @param likeCount Amount of likes the post has.
     * @param dislikeCount Amount of dislikes the post has.
     * @param comments List of comments made in the Post.
     */
    public Post(User author, Community community, String textContent, int likeCount, int dislikeCount, List<Comment> comments)
    {
        this.author = author;
        this.community = community;
        this.textContent = textContent;
        this.likeCount = likeCount;
        this.dislikeCount = dislikeCount;
        this.comments = new ArrayList<>();
    } 

    /**
     * Retrieves the community the Post object belongs to.
     * 
     * @return community
     */
    public Community getCommunity()
    {
        return community;
    }

    /**
     * Retrieves the Post objects text content.
     * 
     * @return textContent
     */
    public String getTextContent()
    {
        return textContent;
    }

    /**
     * Retrieves the Post objects like count.
     * 
     * @return likeCount
     */
    public int getLikeCount()
    {
        return likeCount;
    }

    /**
     * Retrieves the Post objects dislike count.
     * 
     * @return dislikeCount
     */
    public int getDisikeCount()
    {
        return dislikeCount;
    }

    /**
     * Retrieves the Post objects comments in a list.
     * 
     * @return comments
     */
    public List<Comment> getComments()
    {
        return comments;
    }

    /**
     * Sets the like count of the post object.
     * 
     * @param likeCount
     */
    public void setLikeCount(int likeCount)
    {
        this.likeCount = likeCount;
    }

    /**
     * Sets the dislike count of the post object.
     * 
     * @param dislikeCount
     */
    public void setDislikeCount(int dislikeCount)
    {
        this.dislikeCount = dislikeCount;
    }

    /**
     * Sets the comment list of a post obejct.
     * 
     * @param comments
     */
    public void setComments(List<Comments> comments)
    {
        this.comments = comments;
    }
}
